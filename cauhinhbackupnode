# 3. Tạo Script Backup thông minh (SỬ DỤNG RENICE)
cat << 'EOF' > /root/auto_backup.sh
#!/bin/bash

# --- QUAN TRỌNG: Tự giảm ưu tiên CPU của chính script này xuống thấp nhất ---
# (Thay thế cho lệnh nice phức tạp gây lỗi syntax cũ)
renice -n 19 -p $$ >/dev/null 2>&1

RCLONE_REMOTE="gdrive:Mysterium_Backups"
LOCAL_TEMP="/tmp/myst_backups"
NODE_IDS=(1 2) 

mkdir -p "$LOCAL_TEMP"

backup_node() {
    local ID=$1
    local VOL="myst-data$ID"
    local NET="my_network_$ID"
    
    # Lấy IP Public
    PUBLIC_IP=$(docker run --rm --network "$NET" curlimages/curl:latest -s --max-time 10 https://api.ipify.org)
    [ -z "$PUBLIC_IP" ] && PREFIX="Unknown_myst$ID" || PREFIX="${PUBLIC_IP}_myst$ID"
    
    # Đuôi .tar (KHÔNG NÉN - GIÚP CPU 1 CORE KHÔNG BỊ LAG)
    FILENAME="${PREFIX}_$(date +%F).tar"
    
    if docker volume inspect "$VOL" >/dev/null 2>&1; then
        echo "📦 Đang xử lý Node $ID ($VOL)..."
        
        # Chỉ đóng gói tar cf (Không nén)
        docker run --rm -v "$VOL":/data:ro -v "$LOCAL_TEMP":/backup alpine tar cf "/backup/$FILENAME" -C /data .
        
        # Upload
        if rclone copy "$LOCAL_TEMP/$FILENAME" "$RCLONE_REMOTE"; then
             echo "✅ Đã backup xong: $FILENAME"
             rm -f "$LOCAL_TEMP/$FILENAME"
        else
             echo "❌ Lỗi Upload Node $ID"
        fi
    fi
}

# Chạy vòng lặp bình thường (Không còn bị lỗi cú pháp nữa)
for id in "${NODE_IDS[@]}"; do
    backup_node "$id"
done

echo "🎉 HOÀN TẤT TOÀN BỘ!"
EOF

chmod +x /root/auto_backup.sh

# 4. Chạy thử nghiệm
