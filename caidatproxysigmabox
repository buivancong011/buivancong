IMG_SBOX="ghcr.io/sagernet/sing-box:v1.8.11"
IMG_TM="traffmonetizer/cli_v2:latest"
CONFIG_DIR="/opt/do_socks_nopass_farm"

# ===================== 2. TỰ ĐỘNG HÓA HẠ TẦNG DIGITALOCEAN =====================
setup_system() {
    echo "⚙️ [INFO] Đang thiết lập hạ tầng mạng tự động cho DigitalOcean..."
    sudo mkdir -p "$CONFIG_DIR"
    sudo modprobe tun || true



    # Đóng đinh IP Forwarding & Thuốc trợ tim TCP
    sudo bash -c 'cat > /etc/sysctl.d/99-do-proxy-farm.conf' <<EOF
net.ipv4.ip_forward=1
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
fs.file-max=2097152
net.netfilter.nf_conntrack_max=2097152
net.ipv4.tcp_keepalive_time=300
net.ipv4.tcp_keepalive_intvl=60
net.ipv4.tcp_keepalive_probes=5
EOF
    sudo sysctl --system >/dev/null 2>&1 || true
}

# ===================== 3. SING-BOX (TUN SOCKS5 KHÔNG PASS) =====================
mk_sbox_config() {
    local cfg="$1" ip="$2" port="$3"
    cat > "$cfg" <<JSON
{
  "log": { "disabled": true },
  "dns": {
    "servers": [
      { "tag": "dns_cloudflare", "address": "tcp://1.1.1.1", "detour": "direct" }
    ],
    "strategy": "ipv4_only"
  },
  "inbounds": [
    {
      "type": "tun", 
      "interface_name": "tun0", 
      "inet4_address": "172.19.0.1/30",
      "auto_route": true, 
      "strict_route": false, 
      "sniff": true, 
      "mtu": 1500 
    }
  ],
  "outbounds": [
    {
      "tag": "proxy", 
      "type": "socks", 
      "server": "${ip}", 
      "server_port": ${port},
      "version": "5"
    },
    { "tag": "direct", "type": "direct" }
  ],
  "route": {
    "auto_detect_interface": true,
    "rules": [
      { "port": 53, "outbound": "direct" },
      { "protocol": "dns", "outbound": "direct" }
    ],
    "final": "proxy"
  }
}
JSON
}

# ===================== 4. LỆNH TRIỂN KHAI =====================
cmd_up() {
    setup_system
    echo "📥 [INFO] Kéo Images..."
    docker pull "$IMG_SBOX" >/dev/null 2>&1 &
    docker pull "$IMG_TM" >/dev/null 2>&1 &
    wait

    echo "🚀 [INFO] Bắt đầu bung lụa 1000 Node SOCKS5 No-Pass..."
    
    local total=${#PROXIES[@]}
    local i=1
    local batch_size=5 

    for spec in "${PROXIES[@]}"; do
        # Tách IP và PORT siêu tốc
        local ip="${spec%:*}"
        local port="${spec#*:}"
        
        (
            local s_name="csbox${i}"
            local tm_name="tm${i}"
            local s_cfg="$CONFIG_DIR/sbox_${i}.json"
            
            docker rm -f "$s_name" "$tm_name" >/dev/null 2>&1 || true
            mk_sbox_config "$s_cfg" "$ip" "$port"
            
            # Bật hầm TUN bằng Sing-box
            docker run -d --name "$s_name" --restart=unless-stopped \
                --privileged --device /dev/net/tun \
                --log-driver none \
                -v "$s_cfg":/etc/sing-box/config.json:ro \
                "$IMG_SBOX" run -c /etc/sing-box/config.json >/dev/null
            
            sleep 1.0 
            
            # Bơm Traffmonetizer vào hầm
            docker run -d --name "$tm_name" --restart=unless-stopped \
                --network="container:$s_name" \
                --log-driver none \
                "$IMG_TM" start accept --token "$TM_TOKEN" --device-name "tm_do_socks_${i}" >/dev/null
        ) & 
        
        if (( i % batch_size == 0 || i == total )); then
            wait 
            echo "⚡ Lên sóng $i / $total Cụm (Load: $(uptime | awk -F'load average:' '{ print $2 }') )"
            sleep 2.0 
        fi
        ((i++))
    done
    echo "====================================================="
    echo "🔥 HOÀN TẤT! HỆ THỐNG SOCKS5 SIÊU TỐC ĐÃ KHỞI CHẠY!"
    echo "====================================================="
}

# ===================== 5. DỌN DẸP =====================
cmd_down() {
    echo "🧹 [INFO] Đang dọn sạch toàn bộ..."
    docker ps -a --format '{{.Names}}' | grep -E '^(csbox|tm)' | xargs -r -n 1 -P 15 docker rm -f >/dev/null 2>&1 || true
    echo "✅ Máy chủ đã sạch bóng."
}

case "${1:-up}" in
    up)     cmd_up ;;
    down)   cmd_down ;;
    *) echo "Chỉ hỗ trợ: up | down"; exit 1 ;;
esac
