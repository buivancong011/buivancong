TM_TOKEN="JoaF9KjqyUjmIUCOMxx6W/6rKD0Q0XTHQ5zlqCEJlXM="

IMG_SBOX="ghcr.io/sagernet/sing-box:v1.8.11"
IMG_TM="traffmonetizer/cli_v2:latest"
CONFIG_DIR="/opt/gcp_sbox_farm"

# ===================== 2. TỐI ƯU KERNEL & FIX MTU =====================
setup_system() {
    echo "⚙️ [INFO] Khởi tạo môi trường Google Cloud (Chế độ An Toàn)..."
    sudo mkdir -p "$CONFIG_DIR"
    sudo modprobe tun || true

    sudo bash -c 'cat > /etc/sysctl.d/99-proxy-farm.conf' <<EOF
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
fs.file-max=2097152
net.netfilter.nf_conntrack_max=2097152
EOF
    sudo sysctl --system >/dev/null 2>&1 || true

    local docker_restarted=0
    sudo mkdir -p /etc/docker /etc/systemd/system/docker.service.d/
    
    if [ ! -f /etc/docker/daemon.json ]; then
        sudo tee /etc/docker/daemon.json > /dev/null <<EOF
{
  "mtu": 1460,
  "dns": ["8.8.8.8", "8.8.4.4"]
}
EOF
        docker_restarted=1
    fi

    if [ ! -f /etc/systemd/system/docker.service.d/override.conf ]; then
        sudo tee /etc/systemd/system/docker.service.d/override.conf > /dev/null <<EOF
[Service]
LimitNOFILE=2097152
LimitNPROC=2097152
EOF
        docker_restarted=1
    fi

    if [ "$docker_restarted" -eq 1 ]; then
        echo "🔄 [INFO] Đang áp dụng bản vá MTU 1460 cho Docker..."
        sudo systemctl daemon-reload
        sudo systemctl restart docker || true
        sleep 3
    fi
}

mk_sbox_config() {
    local cfg="$1" ip="$2" port="$3"
    cat > "$cfg" <<JSON
{
  "log": { "disabled": true },
  "dns": { 
    "servers": [{ "tag": "dns_direct", "address": "udp://8.8.8.8", "detour": "direct" }], 
    "strategy": "ipv4_only" 
  },
  "inbounds": [{ 
    "type": "tun", "interface_name": "tun0", "inet4_address": ["172.19.0.1/30"], 
    "auto_route": true, "strict_route": false, "mtu": 1400 
  }],
  "outbounds": [
    { "tag": "proxy", "type": "socks", "server": "${ip}", "server_port": ${port}, "version": "5" },
    { "tag": "direct", "type": "direct" }
  ],
  "route": { "auto_detect_interface": true, "rules": [{ "port": 53, "outbound": "direct" }], "final": "proxy" }
}
JSON
}

# ===================== 3. LỆNH TRIỂN KHAI (CHẾ ĐỘ RÓN RÉN) =====================
cmd_up() {
    setup_system
    echo "📥 [INFO] Kéo tải Images mới nhất..."
    docker pull "$IMG_SBOX" >/dev/null 2>&1 &
    docker pull "$IMG_TM" >/dev/null 2>&1 &
    wait

    echo "🐢 [INFO] Bắt đầu bung hệ thống (Chế độ Rón Rén - Chống Spam GCP)..."
    
    local total=${#PROXIES[@]}
    local i=1

    for spec in "${PROXIES[@]}"; do
        IFS=':' read -r ip port ignore_user ignore_pass <<<"$spec"
        
        local s_name="csbox${i}"
        local tm_name="tm${i}"
        local s_cfg="$CONFIG_DIR/sbox_${i}.json"
        
        docker rm -f "$s_name" "$tm_name" >/dev/null 2>&1 || true
        mk_sbox_config "$s_cfg" "$ip" "$port"
        
        # 1. Khởi động Proxy
        docker run -d --name "$s_name" --restart=unless-stopped \
            --cap-add=NET_ADMIN --device /dev/net/tun \
            --log-driver none -v "$s_cfg":/etc/sing-box/config.json:ro \
            "$IMG_SBOX" run -c /etc/sing-box/config.json >/dev/null
        
        # Thở 1 giây để OS kịp tạo card mạng ảo
        sleep 1.0 

        # 2. Khởi động TM
        docker run -d --name "$tm_name" --restart=unless-stopped \
            --network="container:$s_name" --log-driver none \
            "$IMG_TM" start accept --token "$TM_TOKEN" --device-name "tm_gcp_${i}" >/dev/null
        
        # 3. NHỊP ĐỘ AN TOÀN GIỮA CÁC CỤM
        sleep 1.5
        
        # Báo cáo tiến độ
        if (( i % 20 == 0 )); then
            echo "✅ Đã dựng an toàn $i / $total Cụm (Tải CPU: $(uptime | awk -F'load average:' '{ print $2 }') )"
        fi
        
        # 🛑 CÚ CHỐT CHỐNG SPAM: Cứ xong 50 cụm, giả vờ ngừng hoạt động 12 giây
        if (( i % 50 == 0 && i != total )); then
            echo "🛑 Đang làm mát hệ thống & đánh lừa AI của Google (Nghỉ 12 giây)..."
            sleep 12
        fi
        
        ((i++))
    done
    
    echo "====================================================="
    echo "🎉 HOÀN TẤT BÌNH AN! Hệ thống đã lọt qua mắt radar."
    echo "👉 Gõ lệnh: ./tên-script status để kiểm tra"
    echo "====================================================="
}

# ===================== 4. DỌN DẸP & TRẠNG THÁI =====================
cmd_down() {
    echo "🧹 [INFO] Đang gỡ bỏ container..."
    # Khi xóa thì gỡ đa luồng mạnh tay được, vì xóa thì Google không đánh giá là Spam mạng
    docker ps -a --format '{{.Names}}' | grep -E '^(csbox|tm)' | xargs -r -n 1 -P 10 docker rm -f >/dev/null 2>&1 || true
    echo "✅ Đã dọn sạch chiến trường."
}

cmd_clean() {
    cmd_down
    sudo rm -rf "$CONFIG_DIR"/*.json || true
    docker system prune -f >/dev/null 2>&1
    echo "✅ Máy chủ đã sạch bóng như mới!"
}

cmd_status() {
    echo "📊 BÁO CÁO NHANH GOOGLE CLOUD:"
    echo "-----------------------------------"
    echo "🌐 Mạng Ảo (Sing-box) : $(docker ps -q --filter name='csbox' | wc -l) / ${#PROXIES[@]}"
    echo "🐝 App Đào Tiền (TM)  : $(docker ps -q --filter name='tm' | wc -l) / ${#PROXIES[@]}"
    echo "-----------------------------------"
    echo "💾 RAM đang rảnh      : $(free -m | awk '/^Mem:/{print $7}') MB"
    echo "🔥 Sức chịu đựng CPU  : $(uptime | awk -F'load average:' '{ print $2 }')"
}

case "${1:-up}" in
    up)     cmd_up ;;
    down)   cmd_down ;;
    clean)  cmd_clean ;;
    status) cmd_status ;;
    *) echo "Nhập sai. Chỉ hỗ trợ: up | down | clean | status"; exit 1 ;;
esac
