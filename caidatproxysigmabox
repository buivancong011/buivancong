# Token của 2 nền tảng
TM_TOKEN="JoaF9KjqyUjmIUCOMxx6W/6rKD0Q0XTHQ5zlqCEJlXM="

# Tên Image Docker
IMG_SBOX="ghcr.io/sagernet/sing-box:v1.8.11"
IMG_TM="traffmonetizer/cli_v2:latest"
IMG_TITAN="nguyenvinhcao123/titanacc4nguyenvinhson:latest"

# Thư mục lưu trữ tĩnh
CONFIG_DIR="/opt/upcloud_combo_auth_farm"

# ===================== 2. TỐI ƯU KERNEL (DÀNH CHO 4 CORE) =====================
setup_system() {
    echo "⚙️ [INFO] Tối ưu hóa Kernel cho hệ thống Combo (TM + Titan) SOCKS5 CÓ PASS..."
    sudo mkdir -p "$CONFIG_DIR"
    sudo modprobe tun || true

    sudo bash -c 'cat > /etc/sysctl.d/99-proxy-farm.conf' <<EOF
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
fs.file-max=2097152
net.netfilter.nf_conntrack_max=2097152
net.ipv4.neigh.default.gc_thresh1=4096
net.ipv4.neigh.default.gc_thresh2=8192
net.ipv4.neigh.default.gc_thresh3=16384
EOF
    sudo sysctl --system >/dev/null 2>&1 || true

    if [[ ! -f /etc/systemd/system/docker.service.d/override.conf ]]; then
        sudo mkdir -p /etc/systemd/system/docker.service.d/
        sudo tee /etc/systemd/system/docker.service.d/override.conf > /dev/null <<EOF
[Service]
LimitNOFILE=2097152
LimitNPROC=2097152
LimitCORE=infinity
EOF
        sudo systemctl daemon-reload && sudo systemctl restart docker || true
        sleep 3
    fi
}

# ===================== 3. HÀM TẠO FILE MẠNG SING-BOX (THÊM USER/PASS) =====================
mk_sbox_config() {
    local cfg="$1" ip="$2" port="$3" user="$4" pass="$5"
    cat > "$cfg" <<JSON
{
  "log": { "disabled": true },
  "dns": { 
    "servers": [{ "tag": "dns_direct", "address": "udp://8.8.8.8", "detour": "direct" }], 
    "strategy": "ipv4_only" 
  },
  "inbounds": [{ 
    "type": "tun", "interface_name": "tun0", "inet4_address": ["172.19.0.1/30"], 
    "auto_route": true, "strict_route": false, "mtu": 1400 
  }],
  "outbounds": [
    { 
      "tag": "proxy", 
      "type": "socks", 
      "server": "${ip}", 
      "server_port": ${port}, 
      "version": "5",
      "username": "${user}",
      "password": "${pass}"
    },
    { "tag": "direct", "type": "direct" }
  ],
  "route": { "auto_detect_interface": true, "rules": [{ "port": 53, "outbound": "direct" }], "final": "proxy" }
}
JSON
}

# ===================== 4. LỆNH TRIỂN KHAI (UP) =====================
cmd_up() {
    setup_system
    echo "📥 [INFO] Kéo tải 3 Images (Sing-box, TM, Titan)..."
    docker pull "$IMG_SBOX" >/dev/null 2>&1 &
    docker pull "$IMG_TM" >/dev/null 2>&1 &
    docker pull "$IMG_TITAN" >/dev/null 2>&1 &
    wait

    echo "🚀 [INFO] Bắt đầu bung lụa! (Mỗi cụm: 1 Proxy cõng 1 TM + 1 Titan)..."
    
    local i=1
    for spec in "${PROXIES[@]}"; do
        # Tách 4 khúc: IP, Port, User, Pass
        local ip=$(echo "$spec" | cut -d':' -f1)
        local port=$(echo "$spec" | cut -d':' -f2)
        local user=$(echo "$spec" | cut -d':' -f3)
        local pass=$(echo "$spec" | cut -d':' -f4)
        
        local s_name="csbox${i}"
        local tm_name="tm${i}"
        local titan_name="titan_forever${i}"
        
        # Dọn sạch 3 container cũ
        docker rm -f "$s_name" "$tm_name" "$titan_name" >/dev/null 2>&1 || true
        
        # --- [1] Bật hầm Proxy Sing-box ---
        local s_cfg="$CONFIG_DIR/sbox_${i}.json"
        
        # Truyền đủ 5 biến vào cấu hình
        mk_sbox_config "$s_cfg" "$ip" "$port" "$user" "$pass"
        
        docker run -d --name "$s_name" --restart=unless-stopped \
            --cap-add=NET_ADMIN --device /dev/net/tun \
            --log-driver none -v "$s_cfg":/etc/sing-box/config.json:ro \
            "$IMG_SBOX" run -c /etc/sing-box/config.json >/dev/null

        # 🛑 CHỜ 1.0 GIÂY cho hầm thông
        sleep 1.0 

        # --- [2] Nhét TM vào hầm ---
        docker run -d --name "$tm_name" --restart=unless-stopped \
            --network="container:$s_name" --log-driver none \
            "$IMG_TM" start accept --token "$TM_TOKEN" --device-name "tm_combo_${i}" >/dev/null

        # --- [3] Nhét Titan vào cùng hầm đó ---
        docker run -d \
            --name "$titan_name" \
            --network="container:$s_name" \
            --cap-add=SYS_ADMIN \
            --restart=always \
            --memory="150m" \
            --cpus="0.3" \
            --log-opt max-size=1m \
            --log-opt max-file=2 \
            "$IMG_TITAN" >/dev/null

        # In tiến trình mỗi 20 cụm
        if (( i % 20 == 0 )); then
            echo "⚡ Đã dựng xong $i / ${#PROXIES[@]} Cụm Combo (Tải CPU: $(uptime | awk -F'load average:' '{ print $2 }') )"
        fi
        
        # 🛑 CHỜ 0.5 GIÂY - Xả tải CPU
        sleep 0.5 
        ((i++))
    done
    echo "====================================================="
    echo "✅ HOÀN TẤT! CỖ MÁY IN TIỀN KÉP (CÓ PASS) ĐÃ SẴN SÀNG!"
    echo "====================================================="
}

# ===================== 5. DỌN DẸP & TRẠNG THÁI =====================
cmd_down() {
    echo "🧹 Đang gỡ bỏ toàn bộ container..."
    docker ps -a --format '{{.Names}}' | grep -E '^(csbox|tm|titan_forever)' | xargs -r -n 1 -P 8 docker rm -f >/dev/null 2>&1 || true
    echo "✅ Đã gỡ sạch sẽ."
}

cmd_clean() {
    cmd_down
    echo "🧹 Dọn dẹp cấu hình mạng..."
    sudo rm -rf "$CONFIG_DIR"/*.json || true
    docker system prune -f >/dev/null 2>&1
    echo "✅ Máy chủ sạch bóng!"
}

cmd_status() {
    echo "📊 THỐNG KÊ HỆ THỐNG COMBO:"
    echo "-----------------------------------"
    echo "🌐 Cửa hầm Sing-box : $(docker ps | grep csbox | wc -l) / ${#PROXIES[@]}"
    echo "🐝 Lính TM          : $(docker ps | grep tm | wc -l) / ${#PROXIES[@]}"
    echo "🪐 Lính Titan       : $(docker ps | grep titan_forever | wc -l) / ${#PROXIES[@]}"
    echo "-----------------------------------"
    echo "💾 RAM đang trống   : $(free -m | awk '/^Mem:/{print $7}') MB"
    echo "🔥 Tải CPU (Load)   : $(uptime | awk -F'load average:' '{ print $2 }')"
}

# ===================== ROUTER =====================
case "${1:-up}" in
    up)     cmd_up ;;
    down)   cmd_down ;;
    clean)  cmd_clean ;;
    status) cmd_status ;;
    *) echo "Lệnh không hợp lệ. Hỗ trợ: up | down | clean | status"; exit 1 ;;
esac
