# Token của Traffmonetizer
TM_TOKEN="JoaF9KjqyUjmIUCOMxx6W/6rKD0Q0XTHQ5zlqCEJlXM="

# Tên Image Docker
IMG_SBOX="ghcr.io/sagernet/sing-box:v1.8.11"
IMG_TM="traffmonetizer/cli_v2:latest"

# Thư mục lưu trữ cấu hình mạng tĩnh
CONFIG_DIR="/opt/gcp_sbox_farm"

# ===================== 2. TỐI ƯU KERNEL (DÀNH CHO GCP 8 Core) =====================
setup_system() {
    echo "[INFO] Tối ưu hóa Kernel Linux cho GCP (8 Core / 64GB RAM)..."
    sudo mkdir -p "$CONFIG_DIR"
    sudo modprobe tun || true

    # Mở rộng giới hạn mạng cực đại cho 2000 Containers
    sudo bash -c 'cat > /etc/sysctl.d/99-gcp-farm.conf' <<EOF
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
fs.file-max=2097152
net.netfilter.nf_conntrack_max=2097152
net.ipv4.neigh.default.gc_thresh1=4096
net.ipv4.neigh.default.gc_thresh2=8192
net.ipv4.neigh.default.gc_thresh3=16384
EOF
    sudo sysctl --system >/dev/null 2>&1 || true

    # Bơm giới hạn file cho hệ thống Docker
    if [[ ! -f /etc/systemd/system/docker.service.d/override.conf ]]; then
        sudo mkdir -p /etc/systemd/system/docker.service.d/
        sudo tee /etc/systemd/system/docker.service.d/override.conf > /dev/null <<EOF
[Service]
LimitNOFILE=2097152
LimitNPROC=2097152
LimitCORE=infinity
EOF
        sudo systemctl daemon-reload && sudo systemctl restart docker || true
        sleep 3
    fi
}

# ===================== 3. HÀM TẠO FILE MẠNG (ĐÃ XÓA USER/PASS) =====================
mk_sbox_config() {
    local cfg="$1" ip="$2" port="$3"
    cat > "$cfg" <<JSON
{
  "log": { "disabled": true },
  "dns": { 
    "servers": [{ "tag": "dns_direct", "address": "udp://8.8.8.8", "detour": "direct" }], 
    "strategy": "ipv4_only" 
  },
  "inbounds": [{ 
    "type": "tun", "interface_name": "tun0", "inet4_address": ["172.19.0.1/30"], 
    "auto_route": true, "strict_route": false, "mtu": 1400 
  }],
  "outbounds": [
    { "tag": "proxy", "type": "socks", "server": "${ip}", "server_port": ${port}, "version": "5" },
    { "tag": "direct", "type": "direct" }
  ],
  "route": { "auto_detect_interface": true, "rules": [{ "port": 53, "outbound": "direct" }], "final": "proxy" }
}
JSON
}

# ===================== 4. LỆNH TRIỂN KHAI (UP) =====================
cmd_up() {
    setup_system
    echo "[INFO] Kéo tải Images mới nhất..."
    docker pull "$IMG_SBOX" >/dev/null 2>&1 &
    docker pull "$IMG_TM" >/dev/null 2>&1 &
    wait

    echo "[INFO] Bắt đầu triển khai 1000 Cụm (Mỗi cụm: 1 Proxy + 1 TM)..."
    echo "⚠️ LƯU Ý GCP: Quá trình này sẽ chạy từ từ để tránh bị Google khóa máy!"
    
    local i=1
    for spec in "${PROXIES[@]}"; do
        # Đã đổi: Chỉ đọc 2 biến IP và PORT từ mảng
        IFS=':' read -r ip port <<<"$spec"
        
        local s_name="csbox${i}"
        local tm_name="tm${i}"
        
        # Dọn xác container cũ
        docker rm -f "$s_name" "$tm_name" >/dev/null 2>&1 || true
        
        # --- [1] Dựng Proxy Sing-box ---
        local s_cfg="$CONFIG_DIR/sbox_${i}.json"
        
        # Truyền đúng 3 biến: Tên file, IP, Port
        mk_sbox_config "$s_cfg" "$ip" "$port"
        
        docker run -d --name "$s_name" --restart=unless-stopped \
            --cap-add=NET_ADMIN --device /dev/net/tun \
            --log-driver none -v "$s_cfg":/etc/sing-box/config.json:ro \
            "$IMG_SBOX" run -c /etc/sing-box/config.json >/dev/null

        # 🛑 NHỊP CHỜ SINH TỬ CỦA GCP
        sleep 1.0 

        # --- [2] Dựng Traffmonetizer ---
        docker run -d --name "$tm_name" --restart=unless-stopped \
            --network="container:$s_name" --log-driver none \
            "$IMG_TM" start accept --token "$TM_TOKEN" --device-name "tm_gcp_${i}" >/dev/null

        # In tiến trình mỗi 20 cụm
        if (( i % 20 == 0 )); then
            echo "🚀 Đã dựng xong $i / ${#PROXIES[@]} Cụm (Tải CPU: $(uptime | awk -F'load average:' '{ print $2 }') )"
        fi
        
        # 🛑 NHỊP CHỜ SINH TỬ SỐ 2
        sleep 0.5 
        
        ((i++))
    done
    echo "====================================================="
    echo "✅ HOÀN TẤT TRIỂN KHAI 2000 CONTAINER LÊN GOOGLE CLOUD!"
    echo "====================================================="
}

# ===================== 5. DỌN DẸP & TRẠNG THÁI =====================
cmd_down() {
    echo "🧹 Đang gỡ bỏ 2000 container (Chạy đa luồng tốc độ cao)..."
    docker ps -a --format '{{.Names}}' | grep -E '^(csbox|tm)' | xargs -r -n 1 -P 16 docker rm -f >/dev/null 2>&1 || true
    echo "✅ Đã gỡ sạch sẽ container."
}

cmd_clean() {
    cmd_down
    echo "🧹 Dọn dẹp cấu hình mạng và rác Docker..."
    sudo rm -rf "$CONFIG_DIR"/*.json || true
    docker system prune -f >/dev/null 2>&1
    echo "✅ Máy chủ đã sạch bóng, sẵn sàng cho chu kỳ mới!"
}

cmd_status() {
    echo "📊 THỐNG KÊ HỆ THỐNG GOOGLE CLOUD:"
    echo "-----------------------------------"
    echo "🌐 Sing-box Proxy : $(docker ps | grep csbox | wc -l) / ${#PROXIES[@]}"
    echo "🐝 Traffmonetizer : $(docker ps | grep tm | wc -l) / ${#PROXIES[@]}"
    echo "-----------------------------------"
    echo "💾 RAM đang trống : $(free -m | awk '/^Mem:/{print $7}') MB"
    echo "🔥 Tải CPU (Load) : $(uptime | awk -F'load average:' '{ print $2 }')"
}

# ===================== ROUTER =====================
case "${1:-up}" in
    up)     cmd_up ;;
    down)   cmd_down ;;
    clean)  cmd_clean ;;
    status) cmd_status ;;
    *) echo "Lệnh không hợp lệ. Hỗ trợ: up | down | clean | status"; exit 1 ;;
esac
