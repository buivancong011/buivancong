#!/bin/bash
TOKEN_PROXYRACK_API="KK3M5OBY1TDBZ97KMJBBYKIV4PE9DIKUXIERYWVA"
MARKER_FILE="/root/.proxyrack_registered_vinh"

echo "=== RESCUE PROXYRACK V3: CHỈ RETRY KHI LIMIT === "

# 1. Random delay 1-60s để dàn hàng ngang 50 con VPS, tránh nghẽn cổ chai API
DELAY=$((RANDOM % 60 + 1))
echo "⏳ Chờ ngẫu nhiên $DELAY giây để xếp hàng..."
sleep $DELAY

CONTAINERS=$(docker ps --format '{{.Names}}' | grep -i 'proxyrack')
[ -z "$CONTAINERS" ] && { echo "❌ Không tìm thấy container!"; exit 0; }

ALL_DONE=true

for container in $CONTAINERS; do
    UUID=$(docker inspect --format '{{range .Config.Env}}{{println .}}{{end}}' "$container" | grep '^UUID=' | cut -d= -f2 | tr -d '\r')
    
    if [ -n "$UUID" ]; then
        IP=$(curl -s --max-time 10 https://api.ipify.org || echo "UnknownIP")
        NAME="Rescue_${container}_${IP//./}"
        
        echo "🚀 Đang check: $container ($UUID)"
        
        while true; do
            API_RESPONSE=$(curl -s -X POST https://peer.proxyrack.com/api/device/add \
              -H "Api-Key: $TOKEN_PROXYRACK_API" \
              -H "Content-Type: application/json" \
              -H "Accept: application/json" \
              -d "{\"device_id\":\"$UUID\",\"device_name\":\"$NAME\"}")
            
            # --- LOGIC LỌC LỖI THÔNG MINH ---
            
            # TRƯỜNG HỢP 1: THÀNH CÔNG
            if echo "$API_RESPONSE" | grep -qE '"success":\s*true'; then
                echo "✅ OK: Đã add mới thành công."
                break

            # TRƯỜNG HỢP 2: ĐÃ CÓ TRÊN DASHBOARD (Taken/Exists) -> COI NHƯ XONG
            elif echo "$API_RESPONSE" | grep -qE "already been taken|already exists"; then
                echo "ℹ️ SKIP: Thiết bị này đã có trên Dashboard rồi."
                break

            # TRƯỜNG HỢP 3: BỊ GIỚI HẠN (Limit Exceeded) -> ĐỢI VÀ CHẠY LẠI
            elif echo "$API_RESPONSE" | grep -q "Requests limit exceeded"; then
                echo "⚠️ LIMIT: Đang kẹt 5req/min. Nghỉ 70s rồi thử lại ngay..."
                sleep 70
                continue # Tiếp tục vòng lặp while để thử lại con này

            # TRƯỜNG HỢP 4: LỖI KHÁC
            else
                echo "❓ LỖI LẠ: $API_RESPONSE. Bỏ qua để sang node khác."
                break
            fi
        done
    fi
    sleep 3 # Nghỉ nhẹ giữa các container trên cùng 1 máy
done

# Cắm cờ để script Cài Đặt lần sau không lôi con này ra đếm ngược nữa
touch "$MARKER_FILE"
echo "✅ Hoàn tất cứu hộ cho máy chủ này!"
