#!/bin/bash
TOKEN_PROXYRACK_API="KK3M5OBY1TDBZ97KMJBBYKIV4PE9DIKUXIERYWVA"
MARKER_FILE="/root/.proxyrack_registered_vinh"

echo "=== RESCUE PROXYRACK V4: QUÉT SẠCH 2 NODE === "

# 1. Random delay 1-60s để dàn hàng ngang các VPS, tránh nghẽn API
DELAY=$((RANDOM % 60 + 1))
echo "⏳ Đang chờ hàng đợi $DELAY giây..."
sleep $DELAY

# Tìm tất cả container có tên proxyrack (thường là proxyrack1, proxyrack2 hoặc pr_main, pr_sub)
CONTAINERS=$(docker ps --format '{{.Names}}' | grep -i 'proxyrack')

if [ -z "$CONTAINERS" ]; then
    echo "❌ Không tìm thấy bất kỳ container Proxyrack nào đang chạy!"
    exit 0
fi

NUM_NODES=$(echo "$CONTAINERS" | wc -l)
echo "🔎 Tìm thấy $NUM_NODES Node trên máy này. Bắt đầu xử lý..."

ALL_SUCCESS=true

for container in $CONTAINERS; do
    echo "------------------------------------------"
    # Móc UUID từ biến môi trường của container đó
    UUID=$(docker inspect --format '{{range .Config.Env}}{{println .}}{{end}}' "$container" | grep '^UUID=' | cut -d= -f2 | tr -d '\r')
    
    if [ -z "$UUID" ]; then
        echo "⚠️  Không tìm thấy UUID cho $container. Bỏ qua."
        continue
    fi

    # Lấy IP Public của máy để đặt tên cho dễ quản lý trên Dashboard
    IP=$(curl -s --max-time 10 https://api.ipify.org || echo "UnknownIP")
    NAME="Rescue_${container}_${IP//./}"
    
    echo "🚀 Đang xử lý: $container | UUID: ${UUID:0:8}..."
    
    while true; do
        API_RESPONSE=$(curl -s -X POST https://peer.proxyrack.com/api/device/add \
          -H "Api-Key: $TOKEN_PROXYRACK_API" \
          -H "Content-Type: application/json" \
          -H "Accept: application/json" \
          -d "{\"device_id\":\"$UUID\",\"device_name\":\"$NAME\"}")
        
        # --- KIỂM TRA PHẢN HỒI ---
        if echo "$API_RESPONSE" | grep -qE '"success":\s*true'; then
            echo "✅ $container: Đã add mới thành công."
            break
        elif echo "$API_RESPONSE" | grep -qE "already been taken|already exists"; then
            echo "ℹ️ $container: Đã có sẵn trên Dashboard."
            break
        elif echo "$API_RESPONSE" | grep -q "Requests limit exceeded"; then
            echo "⚠️ LIMIT: Đang kẹt 5req/min. Nghỉ 70 giây rồi nã lại..."
            sleep 70
            continue 
        else
            echo "❓ Phản hồi lạ: $API_RESPONSE"
            break
        fi
    done
    # Nghỉ 5s giữa 2 Node trong cùng 1 máy để tránh tự mình làm nghẽn mình
    sleep 5
done

# CHỈ CẮM CỜ KHI ĐÃ XỬ LÝ XONG TẤT CẢ CONTAINER
touch "$MARKER_FILE"
echo "=========================================="
echo "✅ HOÀN TẤT: Đã xử lý xong $NUM_NODES Node!"
