MY_TOKEN='{"access_token":"ya29.a0ATkoCc7ankqGNauZI5ba2fhwxEU6Bxu2kdHhfKbfDb2Mg2A2XoM5uXAvO3yjCIav-wgmxmv7OD76FHFVhqEeo-Es5wp-Pa_-QhjUDAnwQhzeH--T9dWC33OGWDfcPts-QQJd29saLOZ-jW_1VxCKzePbpdAG3OXkXdW8SKTySzH_s7EV6QqqeKg0PgZ85fJR0EKUBNIaCgYKARESARISFQHGX2MiBcHKKR3o_G3gFqSHzOg1zQ0206","token_type":"Bearer","refresh_token":"1//0e5e8ZmSOBcRLCgYIARAAGA4SNwF-L9Irxzx21n-zPpq_Ls-_Pzb93QsnZUDSxi_Vspvfpogmh8bHeXDq4ZAaZTarsEk3E0WvITQ","expiry":"2026-03-22T03:54:15.1115498+07:00"}'
# ==============================================================================

echo "🚀 ĐANG KHỞI CHẠY HỆ THỐNG BACKUP VÍ MYSTERIUM (CHẠY 1 LẦN)..."

# ==========================================
# 1. TỰ ĐỘNG NHẬN DIỆN OS & CÀI ĐẶT TOOLS
# ==========================================
if command -v apt-get &> /dev/null; then
    echo "[+] Phát hiện Debian/Ubuntu. Đang cài tools..."
    export DEBIAN_FRONTEND=noninteractive
    sudo apt-get update -qq >/dev/null 2>&1
    sudo apt-get install -y -q unzip curl grep util-linux >/dev/null 2>&1
elif command -v yum &> /dev/null; then
    echo "[+] Phát hiện RHEL (Amazon Linux/Alibaba). Đang cài tools..."
    sudo yum install -y -q unzip curl grep util-linux >/dev/null 2>&1
else
    echo "❌ Không nhận diện được OS. Dừng script!"
    exit 1
fi

# Cài đặt Rclone nếu chưa có
if ! command -v rclone &> /dev/null; then
    echo "[+] Đang cài đặt Rclone..."
    curl -s https://rclone.org/install.sh | sudo bash >/dev/null 2>&1
fi

# ==========================================
# 2. KHỞI TẠO CẤU HÌNH RCLONE
# ==========================================
RCLONE_CONF_DIR="/root/.config/rclone"
mkdir -p "$RCLONE_CONF_DIR"
cat << EOF > "$RCLONE_CONF_DIR/rclone.conf"
[gdrive]
type = drive
scope = drive
token = $MY_TOKEN
EOF

# ==========================================
# 3. THỰC THI LỆNH BACKUP TRỰC TIẾP
# ==========================================
echo "----------------------------------------------------------------"
echo "📦 BẮT ĐẦU QUÉT VÀ ĐÓNG GÓI DỮ LIỆU NODE..."

# Tối ưu I/O và CPU (chống lag máy cho VPS 1 Core)
renice -n 19 -p $$ >/dev/null 2>&1 || true
ionice -c 3 -p $$ >/dev/null 2>&1 || true

RCLONE_REMOTE="gdrive:Mysterium_Backups"
LOCAL_TEMP="/root/tmp_backup"
mkdir -p "$LOCAL_TEMP"

# Quét động toàn bộ volume Mysterium
MYST_VOLUMES=$(docker volume ls -q | grep -E "^myst-data[0-9]*$")

if [ -z "$MYST_VOLUMES" ]; then
    echo "⚠️ Không tìm thấy Volume Mysterium nào để Backup."
    exit 0
fi

for VOL in $MYST_VOLUMES; do
    # Bóc tách ID (Ví dụ: myst-data3 -> ID=3. myst-data -> ID rỗng)
    ID=${VOL#myst-data}
    
    # ==========================================
    # CƠ CHẾ ĐỊNH TUYẾN MẠNG & TÊN FILE CHUẨN XÁC
    # ==========================================
    if [ -z "$ID" ]; then
        # Dành cho máy 1 Node (Linode)
        NET="bridge"
        SUFFIX="MainNode"  # Tạo file dạng: IP_MainNode_Date.tar
    else
        # Dành cho máy Đa Node (AWS, UpCloud, DO, Azure...)
        NET="my_network_$ID"
        SUFFIX="myst$ID"   # Tạo file dạng: IP_myst1_Date.tar (Khớp 100% tên cũ)
        
        # Fallback: Nếu mạng riêng bị xóa/lỗi, lùi về mạng bridge mặc định
        if ! docker network inspect "$NET" >/dev/null 2>&1; then
            NET="bridge"
        fi
    fi

    echo "👉 Đang xử lý: $VOL (Sử dụng mạng: $NET)"

    # BẮT IP PUBLIC CHUẨN XÁC QUA API.IPIFY.ORG
    PUBLIC_IP=$(docker run --rm --network "$NET" alpine wget -qO- --timeout=10 https://api.ipify.org 2>/dev/null || echo "")
    
    if [ -z "$PUBLIC_IP" ]; then
        echo "   ⚠️ CẢNH BÁO: Không thể lấy IP Public cho $VOL. Gắn mác UnknownIP."
        PUBLIC_IP="UnknownIP"
    else
        echo "   🌐 Đã lấy được IP Public: $PUBLIC_IP"
    fi
    
    # Format File chuẩn tương thích ngược
    FILENAME="${PUBLIC_IP}_${SUFFIX}_$(date +%F).tar"
    
    # Đóng gói TAR (Không nén để giảm tải CPU)
    echo "   📦 Đang đóng gói dữ liệu thành: $FILENAME"
    docker run --rm -v "$VOL":/data:ro -v "$LOCAL_TEMP":/backup alpine tar cf "/backup/$FILENAME" -C /data .
    
    # Đẩy lên Google Drive
    echo "   ☁️  Đang Upload lên Google Drive..."
    if rclone --config "$RCLONE_CONF_DIR/rclone.conf" copy "$LOCAL_TEMP/$FILENAME" "$RCLONE_REMOTE"; then
         echo "   ✅ Upload THÀNH CÔNG!"
         rm -f "$LOCAL_TEMP/$FILENAME"
    else
         echo "   ❌ Upload THẤT BẠI!"
    fi
    echo "-------------------------------------"
done

echo "🎉 TOÀN BỘ QUÁ TRÌNH BACKUP ĐÃ HOÀN TẤT TRỌN VẸN!"
