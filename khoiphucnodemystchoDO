#!/bin/bash
set -e

# ==============================================================================
# 0. TIẾP NHẬN IP ĐẦU VÀO (Không giới hạn số lượng IP)
# ==============================================================================
OLD_IPS=("$@")
if [ ${#OLD_IPS[@]} -eq 0 ]; then
    echo "❌ LỖI: Thiếu IP đầu vào!"
    echo "👉 Cú pháp: ./restore.sh <IP_CŨ_1> [IP_CŨ_2] [IP_CŨ_3]..."
    echo "👉 Ví dụ: ./restore.sh 157.245.20.29 178.128.205.190"
    exit 1
fi

echo "🚀 ĐANG KHỞI CHẠY HỆ THỐNG KHÔI PHỤC UNIVERSAL CHO ${#OLD_IPS[@]} IP..."

# ==============================================================================
# 1. CẤU HÌNH TOKEN (Đã cập nhật Token mới nhất của ông)
# ==============================================================================
MY_TOKEN='{"access_token":"ya29.a0ATkoCc7ankqGNauZI5ba2fhwxEU6Bxu2kdHhfKbfDb2Mg2A2XoM5uXAvO3yjCIav-wgmxmv7OD76FHFVhqEeo-Es5wp-Pa_-QhjUDAnwQhzeH--T9dWC33OGWDfcPts-QQJd29saLOZ-jW_1VxCKzePbpdAG3OXkXdW8SKTySzH_s7EV6QqqeKg0PgZ85fJR0EKUBNIaCgYKARESARISFQHGX2MiBcHKKR3o_G3gFqSHzOg1zQ0206","token_type":"Bearer","refresh_token":"1//0e5e8ZmSOBcRLCgYIARAAGA4SNwF-L9Irxzx21n-zPpq_Ls-_Pzb93QsnZUDSxi_Vspvfpogmh8bHeXDq4ZAaZTarsEk3E0WvITQ","expiry":"2026-03-22T03:54:15.1115498+07:00"}'
RCLONE_REMOTE="gdrive:Mysterium_Backups"
TEMP_DIR="/root/restore_temp"

# ==========================================
# 2. TỰ ĐỘNG NHẬN DIỆN OS & CÀI ĐẶT TOOLS
# ==========================================
if command -v apt-get &> /dev/null; then
    echo "[+] Phát hiện Debian/Ubuntu. Đang cài tools..."
    export DEBIAN_FRONTEND=noninteractive
    sudo apt-get update -qq >/dev/null 2>&1
    sudo apt-get install -y -q unzip curl grep >/dev/null 2>&1
elif command -v yum &> /dev/null; then
    echo "[+] Phát hiện RHEL (Amazon Linux/Alibaba). Đang cài tools..."
    sudo yum install -y -q unzip curl grep >/dev/null 2>&1
else
    echo "❌ Không nhận diện được OS. Dừng script!"
    exit 1
fi

if ! command -v rclone &> /dev/null; then
    curl -s https://rclone.org/install.sh | sudo bash >/dev/null 2>&1
fi

if ! command -v docker &> /dev/null; then
    curl -fsSL https://get.docker.com | sh >/dev/null 2>&1
    sudo systemctl enable --now docker
fi

# ==========================================
# 3. KHỞI TẠO CẤU HÌNH RCLONE
# ==========================================
mkdir -p /root/.config/rclone
cat << EOF > /root/.config/rclone/rclone.conf
[gdrive]
type = drive
scope = drive
token = $MY_TOKEN
EOF
mkdir -p "$TEMP_DIR"

if ! rclone lsd gdrive: >/dev/null 2>&1; then
    echo "❌ LỖI: Token Google Drive lỗi hoặc đã hết hạn. Hãy cập nhật Token!"
    exit 1
fi

# ==========================================
# 4. HÀM KHÔI PHỤC THÔNG MINH (TỰ NHẬN DIỆN VOLUME)
# ==========================================
restore_process() {
    local TARGET_IP=$1
    echo "--------------------------------------------------------"
    echo "🔍 Đang tìm bản Backup mới nhất cho IP: $TARGET_IP"

    # Lấy file mới nhất chứa IP này trên Google Drive
    FILE_NAME=$(rclone lsf "$RCLONE_REMOTE" --files-only | grep "$TARGET_IP" | sort -r | head -n 1)

    if [ -z "$FILE_NAME" ]; then
        echo "❌ LỖI: Không tìm thấy file backup nào cho IP $TARGET_IP trên Drive!"
        return 1 # Bỏ qua IP này và chạy tiếp IP khác
    fi

    echo "📥 Đã tìm thấy: $FILE_NAME"

    # ==========================================
    # CƠ CHẾ ĐỌC NÃO FILE: HỖ TRỢ CẢ FILE CŨ LẪN MỚI
    # Tự động tìm đúng Volume (myst-data1, myst-data2...)
    # ==========================================
    if echo "$FILE_NAME" | grep -q "MainNode"; then
        VOL_NAME="myst-data"
    elif echo "$FILE_NAME" | grep -qE "(Node|myst)[0-9]+"; then
        # Bóc tách con số từ chuỗi NodeX hoặc mystX (VD: myst2 -> lấy số 2)
        ID_NUM=$(echo "$FILE_NAME" | grep -oE "(Node|myst)[0-9]+" | grep -oE "[0-9]+")
        VOL_NAME="myst-data${ID_NUM}"
    else
        VOL_NAME="myst-data" # Mặc định an toàn
    fi

    echo "🎯 Đích đến dự kiến: Docker Volume [$VOL_NAME]"
    
    # Tải file về máy
    echo "☁️  Đang tải từ Google Drive..."
    if ! rclone copyto "$RCLONE_REMOTE/$FILE_NAME" "$TEMP_DIR/temp_backup.tar"; then
        echo "❌ LỖI: Tải file thất bại."
        return 1
    fi

    # Tạo volume Docker mới cứng để khôi phục "vô trùng"
    echo "♻️  Đang xả nén dữ liệu vào $VOL_NAME..."
    docker volume rm "$VOL_NAME" >/dev/null 2>&1 || true
    docker volume create "$VOL_NAME" >/dev/null 2>&1
    
    # Xả nén bằng Alpine
    if ! docker run --rm -v "$VOL_NAME":/data -v "$TEMP_DIR":/backup alpine tar xf "/backup/temp_backup.tar" -C /data; then
         echo "❌ LỖI: Bung nén thất bại."
         return 1
    fi

    rm -f "$TEMP_DIR/temp_backup.tar"
    echo "✅ Khôi phục THÀNH CÔNG cho IP $TARGET_IP vào $VOL_NAME!"
}

# ==========================================
# 5. VÒNG LẶP THỰC THI CHO TẤT CẢ IP
# ==========================================
echo "Bắt đầu tiến trình..."
for IP in "${OLD_IPS[@]}"; do
    restore_process "$IP" || echo "⚠️ Đã bỏ qua khôi phục cho $IP do có lỗi."
done

# Dọn dẹp rác
rm -rf "$TEMP_DIR"
echo "========================================================"
echo "🎉 TOÀN BỘ TIẾN TRÌNH RESTORE ĐÃ HOÀN TẤT TRỌN VẸN!"
