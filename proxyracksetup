#!/bin/bash
set -e

# ==========================================
# 1. CẤU HÌNH API KEY PROXYRACK
# ==========================================
TOKEN_PROXYRACK_API="KK3M5OBY1TDBZ97KMJBBYKIV4PE9DIKUXIERYWVA"

# ==== CẤU HÌNH TỐI ƯU (DNS CLOUDFLARE) ====
DNS_OPTS="--dns 1.1.1.1 --dns 1.0.0.1"

# Mảng lưu thông tin để gọi API Proxyrack
declare -a PR_UUIDS
declare -a PR_NAMES

# Hàm log
log() { echo -e "\e[32m[INFO] $1\e[0m"; }
warn() { echo -e "\e[33m[WARN] $1\e[0m"; }
err() { echo -e "\e[31m[ERROR] $1\e[0m"; exit 1; }

# ==========================================
# 2. KIỂM TRA CPU (CHỐT CHẶN ARM)
# ==========================================
log "Đang kiểm tra kiến trúc CPU máy chủ..."
ARCH=$(uname -m)
if [[ "$ARCH" == "aarch64" ]]; then
  err "❌ Phát hiện ARM64 CPU (Graviton). Proxyrack CHỈ hỗ trợ x86/AMD64. Dừng cài đặt!"
else
  log "✅ Phát hiện AMD64/x86 CPU. Tiếp tục..."
fi

# ==========================================
# 3. CHUẨN BỊ MÔI TRƯỜNG CHO AMAZON LINUX 2023
# ==========================================
log "Cài đặt các công cụ phụ trợ..."
sudo yum install -y -q jq coreutils >/dev/null 2>&1 || true

if ! command -v docker &> /dev/null; then
  log "Cài đặt Docker..."
  sudo yum update -y -q
  sudo yum install -y -q docker
  sudo systemctl enable --now docker
fi

log "Dọn dẹp container Proxyrack cũ..."
if [ -n "$(sudo docker ps -aq --filter "name=^proxyrack")" ]; then 
  sudo docker rm -f $(sudo docker ps -aq --filter "name=^proxyrack") >/dev/null 2>&1 || true
fi

# ==========================================
# 4. BẮT IP TRÊN INTERFACE ENX0
# ==========================================
log "Đang bắt IP trên interface enX0..."

IP_ALLA=$(/sbin/ip -4 -o addr show scope global noprefixroute enX0 | awk '{gsub(/\/.*/,"",$4); print $4}' | head -n 1)
IP_ALLB=$(/sbin/ip -4 -o addr show scope global dynamic enX0 | awk '{gsub(/\/.*/,"",$4); print $4}' | head -n 1)

if [ -z "$IP_ALLA" ] || [ -z "$IP_ALLB" ]; then 
    err "Không lấy được IP trên enX0! Hãy kiểm tra lại."
fi

log "👉 IP Bắt được: A=$IP_ALLA | B=$IP_ALLB"

# ==========================================
# 5. TẠO NETWORK & CẤU HÌNH IPTABLES
# ==========================================
ensure_network() {
  local NET=$1; local SUB=$2
  if sudo docker network inspect "$NET" >/dev/null 2>&1; then
      sudo docker network rm "$NET" >/dev/null
  fi
  sudo docker network create "$NET" --driver bridge --subnet "$SUB" >/dev/null
}

# Dùng dải IP LAN khác biệt để không đụng chạm các app khác
ensure_network "pr_network_1" "192.168.43.0/24"
ensure_network "pr_network_2" "192.168.44.0/24"

log "Cấu hình IPTables SNAT cho Proxyrack..."
sudo iptables -t nat -D POSTROUTING -s 192.168.43.0/24 -j SNAT --to-source ${IP_ALLA} 2>/dev/null || true
sudo iptables -t nat -D POSTROUTING -s 192.168.44.0/24 -j SNAT --to-source ${IP_ALLB} 2>/dev/null || true
sudo iptables -t nat -I POSTROUTING -s 192.168.43.0/24 -j SNAT --to-source ${IP_ALLA}
sudo iptables -t nat -I POSTROUTING -s 192.168.44.0/24 -j SNAT --to-source ${IP_ALLB}

sleep 2

# ==========================================
# 6. KHỞI CHẠY CONTAINER PROXYRACK
# ==========================================
log "🚀 Đang Pull Image Proxyrack..."
sudo docker pull proxyrack/pop:latest >/dev/null 2>&1

run_proxyrack() {
  local ID=$1; local NET="pr_network_$1"; local BIND_IP=$2
  
  # Tạo UUID và tên thiết bị chuẩn sạch
  local PR_UUID=$(echo -n "${BIND_IP}-Proxyrack-Vinh" | sha256sum | awk '{print toupper($1)}')
  local CLEAN_IP="${BIND_IP//./}"
  local PR_NAME="ProxyrackNode${ID}IP${CLEAN_IP}"

  log "  -> Khởi chạy Node $ID (IP: $BIND_IP) | UUID: ${PR_UUID:0:8}..."

  sudo docker run -d --network $NET --restart always $DNS_OPTS \
    -e UUID="$PR_UUID" \
    --name proxyrack$ID proxyrack/pop:latest >/dev/null

  # Lưu data để xài API
  PR_UUIDS+=("$PR_UUID")
  PR_NAMES+=("$PR_NAME")
}

run_proxyrack 1 "$IP_ALLA"
run_proxyrack 2 "$IP_ALLB"

log "==== ĐÃ CHẠY XONG DOCKER PROXYRACK ===="
sudo docker ps --format "table {{.Names}}\t{{.Status}}" | grep "proxyrack" || true

# ==========================================
# 7. GỌI API ĐĂNG KÝ THIẾT BỊ (ĐỢI 2 PHÚT)
# ==========================================
if [ ${#PR_UUIDS[@]} -gt 0 ]; then
    echo ""
    warn "⏳ Đang đợi 2 phút để container kết nối tới máy chủ chủ..."
    for i in {120..1}; do
        printf "\r⏳ Còn lại %3d giây..." "$i"
        sleep 1
    done
    echo -e "\n"

    log "🚀 Đang gọi API thêm thiết bị lên Dashboard Proxyrack..."
    for j in "${!PR_UUIDS[@]}"; do
        UUID="${PR_UUIDS[$j]}"
        NAME="${PR_NAMES[$j]}"
        
        log "Gửi đăng ký cho: $NAME"
        
        API_RESPONSE=$(curl -s -X POST https://peer.proxyrack.com/api/device/add \
          -H "Api-Key: $TOKEN_PROXYRACK_API" \
          -H "Content-Type: application/json" \
          -H "Accept: application/json" \
          -d "{\"device_id\":\"$UUID\",\"device_name\":\"$NAME\"}")
        
        echo "$API_RESPONSE" | jq . 2>/dev/null || echo "$API_RESPONSE"
    done
    log "🎉 HOÀN TẤT SETUP PROXYRACK!"
fi
