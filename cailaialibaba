#!/bin/bash
set -e  # Dừng ngay nếu có lỗi nghiêm trọng

# ==========================================
# 1. CẤU HÌNH TÀI KHOẢN (SỬA 1 LẦN DÙNG CHUNG)
# ==========================================
TOKEN_TM="/PfkwR8qQMfbsCMrSaaDhsX96E9w2PeHH2bcGeyFBno="
TOKEN_EARNFM="50f04bbe-94d9-4f6a-82b9-b40016bd4bbb"
RP_EMAIL="nguyenvinhson000@gmail.com"
RP_API="cad6dcce-d038-4727-969b-d996ed80d3ef"
UR_USER="nguyenvinhcao123@gmail.com"
UR_PASS="CAOcao123CAO@"

# ==== CẤU HÌNH BITPING ====
EMAIL_BITPING="nguyenvinhcao123@gmail.com"
PASS_BITPING="nguyenvinhcao123@gmail.com"

# ==== CẤU HÌNH DNS & DOCKER OPTS (LOG + LIMIT) ====
DNS_OPTS="--dns 1.1.1.1 --dns 1.0.0.1"
# Giới hạn log 30MB + Mở khóa 1 triệu kết nối cho mỗi container
DOCKER_OPTS="--log-opt max-size=5m --log-opt max-file=2 --ulimit nofile=1048576:1048576"

# ==========================================
# 2. HÀM LOG & KIỂM TRA MÔI TRƯỜNG
# ==========================================
log() { echo -e "\e[32m[INFO] $1\e[0m"; }
warn() { echo -e "\e[33m[WARN] $1\e[0m"; }
err() { echo -e "\e[31m[ERROR] $1\e[0m"; exit 1; }

log "Đang kiểm tra kiến trúc CPU..."
ARCH=$(uname -m)

# ==========================================
# 3. NHẬN DIỆN OS & CÀI ĐẶT PHỤ TRỢ
# ==========================================
log "Nhận diện Hệ điều hành (Debian 12 / Alibaba Cloud Linux 3)..."
if grep -qi "debian\|ubuntu" /etc/os-release 2>/dev/null; then
    export DEBIAN_FRONTEND=noninteractive
    sudo apt-get update -q
    sudo apt-get install -y -q jq coreutils curl iproute2 >/dev/null 2>&1
elif grep -qi "alibaba\|centos\|rhel\|rocky" /etc/os-release 2>/dev/null || [ -f /etc/redhat-release ]; then
    sudo yum install -y -q jq coreutils curl iproute >/dev/null 2>&1
fi

if ! command -v docker &> /dev/null; then
  log "Đang cài đặt Docker bản mới nhất..."
  curl -fsSL https://get.docker.com | sh >/dev/null 2>&1
  sudo systemctl enable --now docker
  log "Docker đã sẵn sàng."
fi

# ==========================================
# 4. TỐI ƯU HIỆU SUẤT (BBR, KERNEL & SWAP)
# ==========================================
log "Tối ưu mạng (BBR, Conntrack 1 Triệu) và Swappiness..."
sudo tee /etc/sysctl.d/99-mmo-node-tuning.conf >/dev/null <<EOF
net.core.rmem_max=4194304
net.core.wmem_max=4194304
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
vm.swappiness=10

net.netfilter.nf_conntrack_max=1048576
net.netfilter.nf_conntrack_tcp_timeout_established=86400
net.ipv4.tcp_tw_reuse=1
net.ipv4.tcp_fin_timeout=15
net.ipv4.ip_local_port_range=1024 65535
EOF
sudo sysctl -p /etc/sysctl.d/99-mmo-node-tuning.conf >/dev/null 2>&1 || true

log "Cấu hình Swap 2GB chống tràn RAM..."
if [ ! -f /swapfile ]; then
    sudo dd if=/dev/zero of=/swapfile bs=1M count=2048 status=none
    sudo chmod 600 /swapfile
    sudo mkswap /swapfile >/dev/null 2>&1
    sudo swapon /swapfile >/dev/null 2>&1
    echo '/swapfile none swap sw 0 0' | sudo tee -a /etc/fstab >/dev/null
fi

# ==========================================
# 5. DỌN DẸP CONTAINER CŨ
# ==========================================
log "Dọn dẹp container cũ..."
docker rm -f tm urnetwork earnfm repocket bitping >/dev/null 2>&1 || true
docker image prune -f >/dev/null 2>&1

# ==========================================
# 6. KÉO IMAGE (SONG SONG)
# ==========================================
log "Đang tải Images..."
docker pull traffmonetizer/cli_v2:latest >/dev/null 2>&1 &
docker pull techroy23/docker-urnetwork:latest >/dev/null 2>&1 &
docker pull earnfm/earnfm-client:latest >/dev/null 2>&1 &
docker pull repocket/repocket:latest >/dev/null 2>&1 &
docker pull bitping/bitpingd:latest >/dev/null 2>&1 &
wait
log "Tải ảnh hoàn tất."

# ==========================================
# 7. KHỞI CHẠY CONTAINER (FULL CẤU HÌNH TỐI ƯU)
# ==========================================
log "🚀 Khởi chạy các ứng dụng cày tiền..."

docker run -d --restart always --name tm $DOCKER_OPTS $DNS_OPTS traffmonetizer/cli_v2:latest start accept --token "$TOKEN_TM" >/dev/null
docker run -d --name urnetwork --restart always --cap-add NET_ADMIN $DOCKER_OPTS $DNS_OPTS -v ur_data:/var/lib/vnstat -e USER_AUTH="$UR_USER" -e PASSWORD="$UR_PASS" techroy23/docker-urnetwork:latest >/dev/null
docker run -d --name earnfm --restart always $DOCKER_OPTS $DNS_OPTS -e EARNFM_TOKEN="$TOKEN_EARNFM" earnfm/earnfm-client:latest >/dev/null
docker run -d --name repocket --restart always $DOCKER_OPTS $DNS_OPTS -e RP_EMAIL="$RP_EMAIL" -e RP_API_KEY="$RP_API" repocket/repocket:latest >/dev/null
docker run -d --name bitping --restart unless-stopped $DOCKER_OPTS $DNS_OPTS -v bitping_data:/root/.bitpingd -e BITPING_EMAIL="$EMAIL_BITPING" -e BITPING_PASSWORD="$PASS_BITPING" bitping/bitpingd:latest >/dev/null

# ==========================================
# 8. HOÀN TẤT
# ==========================================
echo "------------------------------------------------------"
log "==== CÀI ĐẶT THÀNH CÔNG - VINH CAO ===="
docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
