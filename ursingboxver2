UR_ENABLE_IP_CHECKER="true"

# Tên Image Docker
IMG_SBOX="ghcr.io/sagernet/sing-box:v1.8.11"
IMG_TM="traffmonetizer/cli_v2:latest"
IMG_EFM="earnfm/earnfm-client:latest"
IMG_UR="nguyenvinhcao123/docker-urnetwork:latest"

# Thư mục lưu trữ tĩnh trên VPS (Giúp dọn dẹp siêu nhanh, không rác)
CONFIG_DIR="/opt/sbox_farm"
DATA_BASE="/opt/earnfm-data"
UR_DATA="/opt/ur-data"

# ===================== 2. TỐI ƯU KERNEL DEBIAN (UPCLOUD 8 CORE / 96GB) =====================
setup_system() {
    echo "[INFO] Tối ưu hóa Kernel Debian cho cấu hình quái vật..."
    sudo mkdir -p "$CONFIG_DIR" "$DATA_BASE" "$UR_DATA"
    sudo modprobe tun || true

    # Mở giới hạn siêu bạo lực cho 1.332 Containers
    sudo bash -c 'cat > /etc/sysctl.d/99-proxy-farm.conf' <<EOF
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
fs.file-max=2097152
net.netfilter.nf_conntrack_max=2097152
net.ipv4.neigh.default.gc_thresh1=4096
net.ipv4.neigh.default.gc_thresh2=8192
net.ipv4.neigh.default.gc_thresh3=16384
EOF
    sudo sysctl --system >/dev/null 2>&1 || true

    # Bơm giới hạn file cho Docker Daemon để không bị ngộp
    if [[ ! -f /etc/systemd/system/docker.service.d/override.conf ]]; then
        sudo mkdir -p /etc/systemd/system/docker.service.d/
        sudo tee /etc/systemd/system/docker.service.d/override.conf > /dev/null <<EOF
[Service]
LimitNOFILE=2097152
LimitNPROC=2097152
LimitCORE=infinity
EOF
        sudo systemctl daemon-reload && sudo systemctl restart docker || true
        sleep 3
    fi
}

# ===================== 3. HÀM TẠO FILE MẠNG (TẮT LOG + BẺ LUỒNG DNS) =====================
mk_sbox_config() {
    local cfg="$1" ip="$2" port="$3" user="$4" pass="$5"
    cat > "$cfg" <<JSON
{
  "log": { "disabled": true },
  "dns": { 
    "servers": [{ "tag": "dns_direct", "address": "udp://8.8.8.8", "detour": "direct" }], 
    "strategy": "ipv4_only" 
  },
  "inbounds": [{ 
    "type": "tun", "interface_name": "tun0", "inet4_address": ["172.19.0.1/30"], 
    "auto_route": true, "strict_route": false, "mtu": 1400 
  }],
  "outbounds": [
    { "tag": "proxy", "type": "socks", "server": "${ip}", "server_port": ${port}, "version": "5", "username": "${user}", "password": "${pass}" },
    { "tag": "direct", "type": "direct" }
  ],
  "route": { "auto_detect_interface": true, "rules": [{ "port": 53, "outbound": "direct" }], "final": "proxy" }
}
JSON
}

# ===================== 4. LỆNH TRIỂN KHAI (UP) =====================
cmd_up() {
    setup_system
    echo "[INFO] Kéo tải Images mới nhất (Chạy ngầm)..."
    docker pull "$IMG_SBOX" >/dev/null 2>&1 &
    docker pull "$IMG_TM" >/dev/null 2>&1 &
    docker pull "$IMG_EFM" >/dev/null 2>&1 &
    docker pull "$IMG_UR" --platform linux/amd64 >/dev/null 2>&1 &
    wait

    echo "[INFO] Dựng 333 Cụm (Mỗi cụm: 1 Proxy + TM + EarnFM + UR)..."
    
    local i=1
    for spec in "${PROXIES[@]}"; do
        IFS=':' read -r ip port user pass <<<"$spec"
        
        local s_name="csbox${i}"
        local tm_name="tm${i}"
        local efm_name="efm-csbox${i}"
        local ur_name="ur-csbox${i}"
        
        # Dọn xác container cũ sạch sẽ (Không in log ra màn hình)
        docker rm -f "$s_name" "$tm_name" "$efm_name" "$ur_name" >/dev/null 2>&1 || true
        
        # --- [1] Proxy Sing-box ---
        local s_cfg="$CONFIG_DIR/sbox_${i}.json"
        mk_sbox_config "$s_cfg" "$ip" "$port" "$user" "$pass"
        
        docker run -d --name "$s_name" --restart=unless-stopped \
            --cap-add=NET_ADMIN --device /dev/net/tun \
            --log-driver none -v "$s_cfg":/etc/sing-box/config.json:ro \
            "$IMG_SBOX" run -c /etc/sing-box/config.json >/dev/null

        sleep 0.7 # Chờ 0.7s để đảm bảo TUN ảo lên thành công, chống lỗi Network Namespace

        # --- [2] Traffmonetizer ---
        docker run -d --name "$tm_name" --restart=unless-stopped \
            --network="container:$s_name" --log-driver none \
            "$IMG_TM" start accept --token "$TM_TOKEN" --device-name "device_tm${i}" >/dev/null

        # --- [3] EarnFM ---
        local efm_data="$DATA_BASE/csbox${i}"
        mkdir -p "$efm_data"
        docker run -d --name "$efm_name" --restart=unless-stopped \
            --network="container:$s_name" --log-driver none \
            -e EARNFM_TOKEN="$EFM_TOKEN" -v "$efm_data":/data \
            "$IMG_EFM" >/dev/null

        # --- [4] UR Network ---
        local ur_vnstat_data="$UR_DATA/csbox${i}"
        mkdir -p "$ur_vnstat_data"
        docker run -d --name "$ur_name" --restart=unless-stopped \
            --network="container:$s_name" \
            --platform linux/amd64 \
            --cap-add=NET_ADMIN \
            --log-driver none \
            -e "USER_AUTH=${UR_USER}" \
            -e "PASSWORD=${UR_PASS}" \
            -e "ENABLE_IP_CHECKER=${UR_ENABLE_IP_CHECKER}" \
            -v "${ur_vnstat_data}:/var/lib/vnstat" \
            "$IMG_UR" >/dev/null

        # In tiến trình mỗi 10 cụm để đỡ trôi màn hình
        if (( i % 10 == 0 )); then
            echo "🚀 Đã dựng xong $i / ${#PROXIES[@]} Cụm..."
        fi
        
        sleep 0.1 # Nghỉ cực ngắn, ép 8 CPU làm việc cường độ cao
        ((i++))
    done
    echo "====================================================="
    echo "✅ HOÀN TẤT TRIỂN KHAI 1.332 CONTAINER LÊN UPCLOUD!"
    echo "👉 Gõ lệnh: ./tên-script status để kiểm tra"
    echo "====================================================="
}

# ===================== 5. DỌN DẸP & TRẠNG THÁI =====================
cmd_down() {
    echo "🧹 Đang gỡ bỏ 1.332 container (Chạy đa luồng 16 luồng siêu tốc)..."
    docker ps -a --format '{{.Names}}' | grep -E '^(csbox|tm|efm|ur)' | xargs -r -n 1 -P 16 docker rm -f >/dev/null 2>&1 || true
    echo "✅ Đã gỡ sạch sẽ container."
}

cmd_clean() {
    cmd_down
    echo "🧹 Dọn dẹp cấu hình mạng và rác Docker..."
    sudo rm -rf "$CONFIG_DIR"/*.json || true
    # KHÔNG xóa thư mục DATA_BASE và UR_DATA để giữ nguyên định danh Node, cày uy tín
    docker system prune -f >/dev/null 2>&1
    echo "✅ Máy chủ đã sạch bóng, sẵn sàng cho chu kỳ mới!"
}

cmd_status() {
    echo "📊 THỐNG KÊ HỆ THỐNG UPCLOUD:"
    echo "-----------------------------------"
    echo "🌐 Sing-box Proxy : $(docker ps | grep csbox | wc -l) / ${#PROXIES[@]}"
    echo "🐝 Traffmonetizer : $(docker ps | grep tm | wc -l) / ${#PROXIES[@]}"
    echo "💸 EarnFM         : $(docker ps | grep efm | wc -l) / ${#PROXIES[@]}"
    echo "🌍 UR App         : $(docker ps | grep ur-csbox | wc -l) / ${#PROXIES[@]}"
    echo "-----------------------------------"
    echo "💾 RAM đang trống : $(free -m | awk '/^Mem:/{print $7}') MB"
    echo "🔥 Tải CPU (Load) : $(uptime | awk -F'load average:' '{ print $2 }')"
}

# ===================== ROUTER ĐIỀU HƯỚNG =====================
case "${1:-up}" in
    up)     cmd_up ;;
    down)   cmd_down ;;
    clean)  cmd_clean ;;
    status) cmd_status ;;
    *) echo "Lệnh không hợp lệ. Hỗ trợ: up | down | clean | status"; exit 1 ;;
esac
